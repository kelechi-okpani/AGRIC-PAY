{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
       "moduleResolution": "node",
    "types": ["node"],
    "lib": ["ES2020"],

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,

    "declaration": true,
    "sourceMap": true,

    "baseUrl": ".",

  "ignoreDeprecations": "5.0",

    "paths": {
      "@config/*": ["src/config/*"],
      "@modules/*": ["src/modules/*"],
      "@middleware/*": ["src/middleware/*"],
      "@shared/*": ["src/shared/*"],
      "@infrastructure/*": ["src/infrastructure/*"],
      "@jobs/*": ["src/jobs/*"],
      "@queues/*": ["src/queues/*"],
      "@events/*": ["src/events/*"],
      "@core/*": ["src/core/*"]
    }
  },

  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}

